<div id="tx-milestone-settings">

  <h3>일정 자동 배치 설정</h3>
  <p>
    <%= check_box_tag "settings[setting_milestone_use_redmine_auto_schedule]", @settings["setting_milestone_use_redmine_auto_schedule"], @settings["setting_milestone_use_redmine_auto_schedule"] == 'true' %>
    <label for="settings_setting_milestone_use_redmine_auto_schedule">레드마인 자동 일정 배치 사용</label>
    <span class="description">레드마인의 기본 자동 스케줄링 기능(set_issue_to_dates)을 설정에 따라 선택적으로 비활성화합니다. <font color="red" style="font-weight: bold;">이 플러그인의 자체 AutoScheduler 로직과 충돌을 방지하기 위해 사용되므로 특별한 경우가 아니면 체크하지 마세요.</font></span>
  </p>

  <% if RedmineTxMilestoneHelper.major_issue_tags_plugin_available? %>
    <% selected_major_issue_tags = RedmineTxMilestoneHelper.major_issue_tag_names(@settings) %>
    <% available_major_issue_tags = (RedmineTxMilestoneHelper.available_major_issue_tags + selected_major_issue_tags).uniq %>

    <br>

    <h3>주요 일감 설정</h3>
    <p>
      <label for="settings_setting_milestone_major_issue_tags">주요 일감 태그</label><br>
      <%= hidden_field_tag "settings[setting_milestone_major_issue_tags][]", "", id: nil %>
      <%= select_tag "settings[setting_milestone_major_issue_tags][]",
                     options_for_select(available_major_issue_tags.map { |tag| [tag, tag] }, selected_major_issue_tags),
                     multiple: true,
                     id: 'settings_setting_milestone_major_issue_tags',
                     size: [[available_major_issue_tags.size, 6].max, 12].min,
                     disabled: available_major_issue_tags.blank?,
                     style: 'min-width: 320px; width: 100%; max-width: 480px;' %>
      <span class="description">선택한 태그 중 하나라도 포함한 일감만 주요 일감으로 간주합니다. 비워두면 기존 기준을 사용합니다.</span>
    </p>
  <% end %>

  <br>

  <h3>이관 대기 일감 설정</h3>
  <p>
    <% selected_review_version_custom_field_ids = RedmineTxMilestoneHelper.review_version_custom_field_ids(@settings) %>
    <% available_review_version_custom_fields = RedmineTxMilestoneHelper.available_review_version_custom_fields %>
    <label for="settings_setting_milestone_review_version_custom_field_ids">이관 대기 일감 목표버전 커스텀필드</label><br>
    <%= hidden_field_tag "settings[setting_milestone_review_version_custom_field_ids][]", "", id: nil %>
    <%= select_tag "settings[setting_milestone_review_version_custom_field_ids][]",
                   options_from_collection_for_select(
                     available_review_version_custom_fields,
                     :id,
                     :name,
                     selected_review_version_custom_field_ids
                   ),
                   multiple: true,
                   id: 'settings_setting_milestone_review_version_custom_field_ids',
                   size: [[available_review_version_custom_fields.size, 4].max, 10].min,
                   disabled: available_review_version_custom_fields.blank?,
                   style: 'min-width: 320px; width: 100%; max-width: 480px;' %>
    <span class="description">선택한 version 타입 이슈 커스텀필드 값이 간트의 목표버전과 같고, 실제 목표버전은 다른 일감을 이관 대기 일감 간트차트에 표시합니다.</span>
  </p>

  <br>

  <h3>마감기한 설정</h3>
  <p class="description">마일스톤 마감일 이전에 표시할 일정 마크를 설정합니다.</p>

  <table class="list" id="milestone-deadlines">
    <thead>
      <tr>
        <th>마감 ?일전</th>
        <th>제목</th>
        <th>마감일</th>
        <th class="buttons"></th>
      </tr>
    </thead>
    <tbody>
      <% deadlines = RedmineTxMilestone::SettingsMigration.get_deadlines(@settings) %>
      <% dev_complete_index = (@settings['setting_milestone_dev_complete_index'] || '0').to_i %>
      <% deadlines.each_with_index do |deadline, idx| %>
      <tr class="deadline-entry">
        <td>
          <%= number_field_tag "settings[setting_milestone_deadlines][][days]",
                               deadline['days'], id: nil, size: 10, min: 1 %>
        </td>
        <td>
          <%= text_field_tag "settings[setting_milestone_deadlines][][title]",
                             deadline['title'], id: nil, size: 30 %>
        </td>
        <td class="deadline-radio">
          <%= radio_button_tag "settings[setting_milestone_dev_complete_index]",
                               idx, idx == dev_complete_index %>
        </td>
        <td class="buttons">
          <a href="#" class="delete-deadline icon-only icon-del" title="삭제"><%= sprite_icon('del', '삭제') %></a>
        </td>
      </tr>
      <% end %>
      <tr>
        <td colspan="3"></td>
        <td class="buttons">
          <a href="#" class="add-deadline icon-only icon-add" title="추가"><%= sprite_icon('add', '추가') %></a>
        </td>
      </tr>
    </tbody>
  </table>

  <br>

  <h3>AI 요약 설정</h3>
  <p>
    <input type="checkbox" name="settings[enable_ai_summary_dashboard]"
           id="settings_enable_ai_summary_dashboard"
           value="true"
           <%= 'checked' if @settings['enable_ai_summary_dashboard'] == 'true' %>>
    <label for="settings_enable_ai_summary_dashboard">대시보드 AI 요약</label>
    <span class="description">대시보드 페이지에서 AI 요약 배너를 표시합니다.</span>
  </p>
  <p>
    <input type="checkbox" name="settings[enable_ai_summary_schedule]"
           id="settings_enable_ai_summary_schedule"
           value="true"
           <%= 'checked' if @settings['enable_ai_summary_schedule'] == 'true' %>>
    <label for="settings_enable_ai_summary_schedule">일정요약 AI 요약</label>
    <span class="description">일정요약 페이지에서 AI 요약 배너를 표시합니다.</span>
  </p>

  <div id="ai-summary-options">
  <p>
    <input type="checkbox" name="settings[use_custom_summary_prompt]"
           id="settings_use_custom_summary_prompt"
           value="true"
           <%= 'checked' if @settings['use_custom_summary_prompt'] == 'true' %>>
    <label for="settings_use_custom_summary_prompt">커스텀 요약 프롬프트 사용</label>
    <span class="description">체크 시 대시보드 AI 요약에 아래 프롬프트가 사용됩니다. 해제 시 내장 프롬프트가 사용됩니다.</span>
  </p>
  <% default_summary_prompt = <<~PROMPT.strip
위 프로젝트 마일스톤 현황 데이터를 바탕으로 프로젝트 매니저에게 보고하는 간결한 현황 요약을 작성해 주세요.

요구사항:
- 5~10문장으로 핵심을 전달
- 가장 심각한 리스크나 주의사항을 먼저 언급
- 일정 미배정 일감이 많은 경우(30% 이상), 일정 리스크 판단 자체가 어려운 상황임을 최우선으로 강조하고, 일정 배정이 선행되어야 한다는 점을 명확히 언급
- 전체적인 진행 상태에 대한 판단 포함
- 주요 일정(빌드 전달일, 마감일 등)의 경과/잔여 상황을 고려하여 현재 시점의 위치를 판단
- 잔여 작업일 정보가 포함된 경우, 실제 작업 가능 일수를 기반으로 일정 리스크를 판단
- 버그 수정 추이가 포함된 경우, 릴리즈까지 버그 해소 전망도 언급
- 마크다운 없이 평문으로 작성
- 한국어로 작성
PROMPT
  %>
  <% summary_prompt_value = @settings['custom_summary_prompt'].present? ? @settings['custom_summary_prompt'] : default_summary_prompt %>
  <textarea name="settings[custom_summary_prompt]"
            id="settings_custom_summary_prompt"
            rows="12"
            style="width: 100%; font-family: monospace;"><%= summary_prompt_value %></textarea>
  <span class="description">데이터 컨텍스트 뒤에 이 프롬프트가 붙어 LLM에 전달됩니다.</span>

  <div style="margin-top: 8px; display: flex; align-items: center; gap: 8px;">
    <select id="test-summary-version">
      <option value="">(자동 선택)</option>
      <% Version.visible.open.includes(:project).order('projects.name ASC, versions.effective_date DESC').each do |v| %>
        <option value="<%= v.id %>"><%= v.project.name %> — <%= v.name %></option>
      <% end %>
    </select>
    <button type="button" id="test-summary-prompt" class="button">테스트</button>
    <span id="test-summary-loading" style="display: none; color: #888;">요약 생성중...</span>
  </div>
  </div>

</div>

<div id="summary-test-modal" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.5); z-index:10000;">
  <div style="position:absolute; top:50%; left:50%; transform:translate(-50%,-50%); background:#fff; border-radius:6px; padding:20px; width:700px; max-width:90vw; max-height:80vh; display:flex; flex-direction:column;">
    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:12px;">
      <strong id="summary-test-title" style="font-size:14px;"></strong>
      <a href="#" id="summary-test-close" style="font-size:18px; text-decoration:none; color:#888;">&times;</a>
    </div>
    <div id="summary-test-body" style="overflow-y:auto; white-space:pre-wrap; line-height:1.6; font-size:13px; flex:1;"></div>
  </div>
</div>

<style>
/* .tabular.settings 상속 스타일 전체 리셋 */
#tx-milestone-settings p {
  padding-left: 0;
  clear: none;
  overflow: visible;
}

#tx-milestone-settings label {
  float: none;
  width: auto;
  margin-left: 0;
  text-align: left;
  font-weight: bold;
}

#tx-milestone-settings input,
#tx-milestone-settings select,
#tx-milestone-settings textarea {
  max-width: none;
}

/* 테이블 스타일 */
#milestone-deadlines {
  width: auto;
  margin-top: 8px;
}

#milestone-deadlines td input[type="number"] {
  width: 80px;
}

#milestone-deadlines td input[type="text"] {
  width: 200px;
}

/* 체크박스 인라인 정렬 */
#tx-milestone-settings p label {
  display: inline;
  margin-right: 4px;
}
</style>

<script>
$(function() {
  var $tbody = $('#milestone-deadlines tbody');

  function reindexRadios() {
    $tbody.find('.deadline-entry').each(function(i) {
      $(this).find('.deadline-radio input[type="radio"]').val(i);
    });
  }

  // 행 삭제
  $tbody.on('click', '.delete-deadline', function(e) {
    e.preventDefault();
    // 최소 1개 행 유지
    if ($tbody.find('.deadline-entry').length > 1) {
      var wasChecked = $(this).closest('tr').find('input[type="radio"]').is(':checked');
      $(this).closest('tr').remove();
      if (wasChecked) {
        $tbody.find('.deadline-entry:first input[type="radio"]').prop('checked', true);
      }
      reindexRadios();
    }
  });

  // 삭제 버튼 HTML 템플릿 (기존 행에서 복사)
  var deleteIconHtml = $tbody.find('.delete-deadline').first().html() ||
    '<span class="icon-label">삭제</span>';

  // 행 추가
  $tbody.on('click', '.add-deadline', function(e) {
    e.preventDefault();
    var nextIndex = $tbody.find('.deadline-entry').length;
    var newRow = '<tr class="deadline-entry">' +
      '<td><input type="number" name="settings[setting_milestone_deadlines][][days]" value="" size="10" min="1"></td>' +
      '<td><input type="text" name="settings[setting_milestone_deadlines][][title]" value="" size="30"></td>' +
      '<td class="deadline-radio"><input type="radio" name="settings[setting_milestone_dev_complete_index]" value="' + nextIndex + '"></td>' +
      '<td class="buttons"><a href="#" class="delete-deadline icon-only icon-del" title="삭제">' +
      deleteIconHtml + '</a></td>' +
      '</tr>';
    $(this).closest('tr').before(newRow);
  });

  // ─── AI 요약 활성화 토글 ───
  var $aiChkDashboard = $('#settings_enable_ai_summary_dashboard');
  var $aiChkSchedule = $('#settings_enable_ai_summary_schedule');
  var $aiSection = $('#ai-summary-options');

  function toggleAiSummary() {
    var on = $aiChkDashboard.is(':checked') || $aiChkSchedule.is(':checked');
    $aiSection.toggle(on);
  }
  $aiChkDashboard.on('change', toggleAiSummary);
  $aiChkSchedule.on('change', toggleAiSummary);
  toggleAiSummary();

  // ─── 커스텀 프롬프트 토글 ───
  var $chk = $('#settings_use_custom_summary_prompt');
  var $ta = $('#settings_custom_summary_prompt');
  var $testBtn = $('#test-summary-prompt');

  function togglePrompt() {
    var on = $chk.is(':checked');
    $ta.prop('disabled', !on).css('opacity', on ? 1 : 0.5);
    $testBtn.prop('disabled', !on);
  }
  $chk.on('change', togglePrompt);
  togglePrompt();

  // ─── 테스트 버튼 ───
  var $loading = $('#test-summary-loading');
  var $modal = $('#summary-test-modal');

  $testBtn.on('click', function() {
    $testBtn.prop('disabled', true);
    $loading.show();

    $.ajax({
      url: '<%= escape_javascript(url_for(controller: "milestone", action: "test_summary_prompt", only_path: true)) %>',
      method: 'POST',
      data: { prompt: $ta.val(), version_id: $('#test-summary-version').val(), authenticity_token: $('meta[name="csrf-token"]').attr('content') },
      dataType: 'json',
      success: function(data) {
        if (data.success) {
          $('#summary-test-title').text(data.project + ' / ' + data.version);
          $('#summary-test-body').text(data.summary);
        } else {
          $('#summary-test-title').text('오류');
          $('#summary-test-body').text(data.error);
        }
        $modal.show();
      },
      error: function(xhr) {
        $('#summary-test-title').text('오류');
        $('#summary-test-body').text('요청 실패: ' + xhr.status);
        $modal.show();
      },
      complete: function() {
        $loading.hide();
        togglePrompt();
      }
    });
  });

  // 모달 닫기
  $('#summary-test-close, #summary-test-modal').on('click', function(e) {
    if (e.target === this) $modal.hide();
  });
});
</script>
