<style>
  #content .tabs.tabs-wrap { height: auto; overflow: visible; }
  #content .tabs.tabs-wrap ul { position: static; min-width: 0; display: flex; flex-wrap: wrap; }
  #content .tabs.tabs-wrap ul li { margin-bottom: 4px; }
</style>
<div class="tabs tabs-wrap">
  <ul>
    <li><%= link_to '🏠 시작', '/projects/' + params[:project_id].to_s + '/milestone', class: action_name == 'index' ? 'selected' : '' %></li>
    <li><%= link_to '📈 대시보드', '/projects/' + params[:project_id].to_s + '/milestone/dashboard', class: action_name == 'dashboard' ? 'selected' : '' %></li>
    <li><%= link_to '📊 간트차트', '/projects/' + params[:project_id].to_s + '/milestone/gantt', class: action_name == 'gantt' ? 'selected' : '' %></li>
    <li><%= link_to '📋 일정요약', '/projects/' + params[:project_id].to_s + '/milestone/schedule_summary', class: action_name == 'schedule_summary' ? 'selected' : '' %></li>
    <li><%= link_to '👥 작업 현황(부서)', '/projects/' + params[:project_id].to_s + '/milestone/group_detail', class: action_name == 'group_detail' ? 'selected' : '' %></li>
    <li><%= link_to '⚡ 일정 자동 배치', '/projects/' + params[:project_id].to_s + '/milestone/tetris', class: action_name == 'tetris' ? 'selected' : '' %></li>
    <li><%= link_to '🔧 검증도구', '/projects/' + params[:project_id].to_s + '/milestone/tools', class: action_name == 'tools' ? 'selected' : '' %></li>
    <li><%= link_to '🔍 일감 통계', '/projects/' + params[:project_id].to_s + '/milestone/report', class: action_name == 'report' ? 'selected' : '' %></li>
  </ul>
</div>