<% if @gantt_issue %>
    <% html_title("##{@gantt_issue.id} [#{@gantt_issue.tracker.name}] #{@gantt_issue.subject.to_s}") %>

    <%= render :partial => 'milestone/gantt_chart', locals: { title: '주요 일감', issues: @gantt_issues, due_date: @gantt_due_date, date_marks: @gantt_issue.fixed_version&.marks || [], gantt_opts: { show_status_history: false } } %>

<% else %>
    <%= render :partial => 'milestone/versions' %>
<% end %>
