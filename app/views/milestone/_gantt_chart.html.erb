<%
  # 다른 컨트롤러(예: UsersController)에서 렌더링될 때도 헬퍼 메서드 사용 가능하도록
  extend RedmineTxMilestoneHelper unless respond_to?(:gantt_paused_periods, true)
%>
<%= gantt_chart_assets %>

<%
  gantt_opts ||= {}
  date_marks ||= []
  virtual_ids ||= []

  issue_link_url = gantt_opts[:issue_link_url] || '/issues/'

  cell_width = gantt_opts[:cell_width] || 18
  cell_height = gantt_opts[:cell_height] || 18
  title_width = gantt_opts[:title_width] || 400
  person_width = gantt_opts[:person_width] || 90
  show_status_history = gantt_opts[:show_status_history] || params[:show_status_history] || false

  # N+1 쿼리 방지 (css_classes가 priority/status를 참조함)
  ActiveRecord::Associations::Preloader.new(
    records: issues,
    associations: [:assigned_to, :project, :status, :priority, :tracker]
  ).call

  # 하위 일감 조회는 단일 쿼리 결과를 공유
  all_descendants = gantt_all_descendants_for(issues)

  # 헬퍼 메서드로 비즈니스 로직 분리
  status_periods_map = gantt_status_periods(issues)
  paused_periods_map = status_periods_map[:paused] || {}
  review_periods_map = status_periods_map[:review] || {}
  depth_map_hash = gantt_depth_map(issues)
  overrun_due_dates = gantt_top_level_overrun_due_dates(issues, all_descendants)
  planning_segments_map = gantt_parent_planning_segments_map(issues, gantt_visible_descendants_for(issues, all_descendants))
  planning_segment_dates = planning_segments_map.values.flatten.flat_map { |segment| [segment[:start_date], segment[:due_date]] }

  _due_date = defined?(due_date) && due_date ? due_date : nil
  date_info = gantt_date_range(issues, gantt_opts, _due_date, overrun_due_dates.values + planning_segment_dates)
  start_date = date_info[:start_date]
  end_date = date_info[:end_date]
  today_index = date_info[:today_index]
  due_date_index = date_info[:due_date_index]
  total_days = date_info[:total_days]
  show_today_column = Date.today >= start_date && Date.today <= end_date
  visible_date_marks = date_marks.select { |data| data[:date] && data[:date] >= start_date && data[:date] <= end_date }

  _issues = gantt_prepare_issues(issues, depth_map_hash, all_descendants)

  holidays = {}
  if TxBaseHelper::HolidayApi.available?
    holidays = TxBaseHelper::HolidayApi.for_date_range( start_date, end_date )
  end

  status_names_by_id = show_status_history ? IssueStatus.all.index_by(&:id) : {}
%>

<%
  gantt_container_id = "gantt-container-#{rand(1000000)}"
  bulk_schedule_update_url = @project ? "/projects/#{@project.identifier}/milestone/gantt/schedules" : nil
%>

<%= form_tag({}, data: { cm_url: issues_context_menu_path }) do %>
<div class="gantt-wrapper mouseover-wrapper-<%=gantt_container_id%>" style="display: flex; position: relative;">
  <div class="cursor-container-<%=gantt_container_id%>" style="top: 36px; height: <%=cell_height%>px;"></div>
  <div class="gantt-bulk-edit-actions" data-gantt-bulk-actions style="display: none;">
    <button type="button" class="gantt-bulk-save" data-gantt-save>Save</button>
    <button type="button" class="gantt-bulk-discard" data-gantt-discard>Discard</button>
  </div>

  <div class="gantt-info-container" style="flex-shrink: 0; border: 1px solid #ccc;">

    <div class="gantt-grid" style="grid-template-columns: <%=title_width%>px <%=person_width%>px;">

        <div class="task-name" style="height: <%=cell_height*2%>px;"><span class="task-name-text"><%= title ? title : '일감' %></span></div>
        <% if gantt_opts[:hide_assignee] != true %>
            <div class="assignee" style="left: <%=title_width%>px;">담당자</div>
        <% end %>


          <% _issues.each do |_issue| %>

            <%
            issue = _issue[:issue]
            depth = _issue[:depth]
            show_no_due_date_warning = _issue[:show_no_due_date_warning]
            show_missing_child_schedule_warning = _issue[:show_missing_child_schedule_warning]
            missing_child_schedule_warning_details = _issue[:missing_child_schedule_warning_details] || []
            %>

            <div id="issue-<%= issue.id %>" class="task-row mouseover-<%=gantt_container_id%> hascontextmenu">
                <input type="checkbox" name="ids[]" value="<%= issue.id %>" style="display:none" />

                <div class="task-name priority-<%= issue.priority_id %>" style="height: <%=cell_height%>px;">
                <% subject_class = gantt_issue_css_class(issue) %>

                <% if depth > 0 then %>
                    <span class="depth-indent" style="margin-left: <%=depth * 10%>px;">▸ </span>
                <% end %>

                <% if virtual_ids.include?(issue.id) then %>
                    <span class="virtual-marker">✨ </span>
                <% end %>

                <% if IssueStatus.is_postponed?(issue.status_id) && !Tracker.is_exception?( issue.tracker_id ) then %>
                    <i class='fas fa-hourglass-half warning-icon icon-postponed'> </i>
                <% end %>

                <% if show_missing_child_schedule_warning then %>
                    <% warning_lines = ['자식 일감 중 완료기한 미기입 있음'] + missing_child_schedule_warning_details.map { |detail| "##{detail[:id]} : #{detail[:subject]} (#{detail[:reason]})" } %>
                    <i class='fas fa-circle-question warning-icon icon-missing-child-schedule' title="<%= warning_lines.join("\n") %>"> </i>
                <% end %>

                <% if IssueStatus.is_discarded?(issue.status_id) then %>
                    <span class="icon-discarded">🗑️</span>
                <% elsif IssueStatus.is_implemented?(issue.status_id) then %>
                    <span class="icon-implemented">✓</span>
                <% elsif IssueStatus.is_in_review?(issue.status_id) then %>
                    🔍
                <% elsif IssueStatus.is_paused?(issue.status_id) then %>
                    <i class='fas fa-pause icon-paused'> </i>
                <% elsif IssueStatus.is_new?(issue.status_id) && issue.start_date && issue.start_date <= Date.today then %>
                    ⚠️
                <% elsif !IssueStatus.is_completed?(issue.status_id) && issue.due_date && issue.due_date < Date.today then %>
                    🔥
                <% end %>
                <span class="issue-subject-link <%= subject_class %>" data-issue-tooltip="<%= issue.id %>">
                    <%= link_to "##{issue.id}", "/projects/#{ @project ? @project.identifier : issue.project.identifier }/milestone/gantt/issues/#{issue.id}" %>
                    <%= link_to issue.subject, gantt_opts[:issue_link_url] ? gantt_opts[:issue_link_url] + issue.id.to_s : issue_path(issue),
                                class: issue.css_classes, title: issue.subject.truncate(100) %>
                </span>

                </div>
                <% if gantt_opts[:hide_assignee] != true %>
                <div class="assignee priority-<%= issue.priority_id %>" style="left: <%=title_width%>px; height: <%=cell_height%>px;"><%= cached_link_to_principal(issue.assigned_to) if issue.assigned_to %></div>
                <% end %>
            </div>
          <% end %>

    </div>
  </div>

  <div id="<%= gantt_container_id %>"
       class="gantt-container"
       data-gantt-sync="true"
       data-gantt-start-date="<%= start_date.iso8601 %>"
       data-gantt-start-jd="<%= start_date.jd %>"
       data-gantt-end-jd="<%= end_date.jd %>"
       data-gantt-cell-width="<%= cell_width %>"
       data-gantt-cell-height="<%= cell_height %>"
       data-gantt-today-index="<%= today_index %>"
       <% if bulk_schedule_update_url %>data-gantt-bulk-update-url="<%= h(bulk_schedule_update_url) %>"<% end %>
       style='border: 1px solid #ccc;'>
    <div class="gantt-grid" style="grid-template-columns: repeat(<%=total_days+1%>, <%=cell_width%>px);">
      <!-- 월 헤더 -->
      <%
        current_month = nil
        month_cell_count = 0

        (start_date..end_date).each do |date|
          if current_month != date.month
            if current_month
      %>
              <div class="month-header" style="grid-column: span <%= month_cell_count %>; white-space: nowrap;"><%= current_month %>월</div>
      <%
            end
            current_month = date.month
            month_cell_count = 1
          else
            month_cell_count += 1
          end

          if date == end_date
      %>
            <div class="month-header" style="height: <%=cell_height - 4%>px; grid-column: span <%= month_cell_count %>;"><%= current_month %>월</div>
      <%
          end
        end
      %>

      <!-- 날짜 헤더 -->
      <% (start_date..end_date).each do |date| %>
        <div class="date-header" <%= date == start_date ? "style='height: #{cell_height - 4}px;'".html_safe : "" %>>
          <span class="date-header-text">

            <font color="<%= date.sunday? ? 'red' : date.saturday? ? 'blue' : 'black' %>"><%= date.day %></font>

            <% if date.sunday? || holidays[date] %>
              <div class="highlight-column" style="width: <%=cell_width%>px; top: <%=cell_height  %>px; left: <%= ((date - start_date).to_i * cell_width) %>px; background-color: rgba(255, 0, 0, 0.1);"></div>
            <% end %>
            <% if date.saturday? %>
              <div class="highlight-column" style="width: <%=cell_width%>px; top: <%=cell_height  %>px; left: <%= ((date - start_date).to_i * cell_width) %>px; background-color: rgba(0, 80, 255, 0.1);"></div>
            <% end %>

            <% vacation = ( ( defined?(user) && defined?(vacation_info) && vacation_info && vacation_info[date] ) ? vacation_info[date].select{ |k, v| k == user.login }[ user.login ] : nil ) %>
            <% if vacation then

                 vacation_left_margin = 0
                 vacation_width = cell_width

                 if vacation[:status] == "오전반차" then
                   vacation_width = vacation_width / 2
                 elsif vacation[:status] == "오후반차" then
                   vacation_left_margin = cell_width / 2
                   vacation_width = vacation_width / 2
                 end
             %>
              <div class="highlight-column" style="left: <%= vacation_left_margin + ((date - start_date).to_i * cell_width) %>px; top: <%=cell_height + 1 %>px; width: <%= vacation_width %>px; background-color: rgba(0, 0, 0, 0.1);"></div>
            <% end %>

          </span>
        </div>
      <% end %>

      <!-- 오늘 날짜 표시선 -->
      <% if show_today_column %>
        <div class="today-column" style="left: <%= (today_index * cell_width) %>px; top: <%=cell_height + 1 %>px;"></div>
        <div class="today-column" style="left: <%= (today_index * cell_width) + cell_width %>px; top: <%=cell_height + 1 %>px;"></div>
      <% end %>
      <% if defined?(due_date) && due_date %>
        <div class="blocked-grid" style="left: <%= (due_date_index * cell_width) %>px; top: <%=cell_height + 1 %>px; width: <%= cell_width * ( ( end_date - due_date ).to_i )  %>px;"></div>
      <% end %>

      <% if visible_date_marks.any? then %>
        <% visible_date_marks.each_with_index do |data, index|
          _value = data[:name]
          _date = data[:date]
          _is_deadline = data[:is_deadline]
          _mark_class = _is_deadline ? ' mark-deadline' : ''
          %>
          <% mark_index = ( _date - start_date ).to_i + 1 %>
            <div class="mark-text<%= _mark_class %>" style="left: <%= 3 + (mark_index * cell_width) %>px; top: <%= index * cell_height + cell_height * 2.2 %>px;"><%= _value %></div>
            <div class="mark-column<%= _mark_class %>" style="left: <%= (mark_index * cell_width) %>px;top: <%=cell_height + 1 %>px"></div>
        <% end %>
      <% end %>

      <%# 일감별 행(lane): 날짜별 빈 셀 대신 행 하나에 절대 위치로 바/라인을 배치 %>
      <% _issues.each do |_issue| %>
        <%
          issue = _issue[:issue]
          show_no_due_date_warning = _issue[:show_no_due_date_warning]

          issue_begin_date = issue.begin_time ? issue.begin_time.to_date : nil
          issue_end_date = issue.end_time ? issue.end_time.to_date : Date.today
          overrun_due_date = overrun_due_dates[issue.id]

          issue_progress_status_history = if show_status_history then
                                                issue.status_history.map{ |datetime, status_id|
                                                  status = status_names_by_id[status_id.to_i]
                                                  [ datetime.to_date, status ? status.name : '?' ]
                                                 }.to_h
                                            else
                                                {}
                                            end

          planning_segments = planning_segments_map[issue.id] || []
          planning_line_bounds = gantt_planning_line_bounds(planning_segments, start_date, end_date)
          issue_schedule_line = !Tracker.is_exception?( issue.tracker_id ) && ( ( issue.due_date && issue.due_date >= start_date ) || ( issue.start_date && issue.due_date.nil? ) || ( issue.start_date && issue.start_date >= start_date && issue.start_date <= end_date ) )
          planning_only_line = !issue_schedule_line && !Tracker.is_exception?( issue.tracker_id ) && planning_line_bounds.present?
          show_line = issue_schedule_line || planning_only_line
          show_line_before = ( issue.start_date && issue.start_date >= start_date )
          show_line_after = ( issue.due_date && issue.due_date <= end_date )

          if planning_only_line
            line_start_date = planning_line_bounds[:start_date]
            line_end_date = planning_line_bounds[:due_date]
            show_line_before = false
            show_line_after = false
          else
            line_start_date = if issue.start_date && issue.start_date < start_date then
                                start_date
                              else
                                issue.start_date
                              end
            line_end_date = if issue.due_date && issue.due_date >= start_date then
                              issue.due_date
                            else
                              end_date
                            end

            if line_start_date.nil? && line_end_date
              line_start_date = if issue.due_date.present?
                                  start_date
                                elsif issue_begin_date && !IssueStatus.is_implemented?( issue.status_id )
                                  issue_begin_date
                                else
                                  line_end_date
                                end
            end
          end

          line_width = line_start_date ? ( [ line_end_date, end_date ].min - line_start_date + 1 ).to_i * cell_width : cell_width
          overrun_extension_width = if overrun_due_date && line_end_date && overrun_due_date > line_end_date
                                      ( [ overrun_due_date, end_date ].min - line_end_date ).to_i * cell_width
                                    else
                                      0
                                    end
          line_hit_width = line_width + overrun_extension_width

          line_in_range = line_start_date && line_start_date >= start_date && line_start_date <= end_date
          line_left = line_in_range ? ( line_start_date - start_date ).to_i * cell_width : nil

          schedule_start_date = issue.start_date&.to_date
          schedule_due_date = issue.due_date&.to_date
          schedule_has_start_date = schedule_start_date.present?
          schedule_has_due_date = schedule_due_date.present?
          schedule_display_start_date = schedule_start_date || (schedule_has_due_date ? line_start_date : nil)
          schedule_display_due_date = schedule_due_date || (schedule_has_start_date ? end_date : nil)
          schedule_anchor_date = start_date
          schedule_virtual = virtual_ids.include?(issue.id)
          schedule_editable_start = !schedule_has_start_date || issue.safe_attribute?('start_date', User.current)
          schedule_editable_due = !schedule_has_due_date || issue.safe_attribute?('due_date', User.current)
          schedule_draggable = (schedule_has_start_date || schedule_has_due_date) &&
                               schedule_display_start_date.present? &&
                               schedule_display_due_date.present? &&
                               schedule_display_start_date >= start_date &&
                               schedule_display_due_date <= end_date &&
                               !Tracker.is_exception?(issue.tracker_id) &&
                               issue.attributes_editable?(User.current) &&
                               schedule_editable_start &&
                               schedule_editable_due
          schedule_update_url = if schedule_draggable
                                  "/projects/#{issue.project.identifier}/milestone/gantt/issues/#{issue.id}/schedule"
                                end
          schedule_drag_attrs = if schedule_draggable
                                  [
                                    'data-gantt-schedule="true"',
                                    "data-issue-id=\"#{issue.id}\"",
                                    "data-has-start-date=\"#{schedule_has_start_date}\"",
                                    "data-has-due-date=\"#{schedule_has_due_date}\"",
                                    "data-start-jd=\"#{schedule_display_start_date.jd}\"",
                                    "data-due-jd=\"#{schedule_display_due_date.jd}\"",
                                    "data-original-start-jd=\"#{schedule_start_date&.jd}\"",
                                    "data-original-due-jd=\"#{schedule_due_date&.jd}\"",
                                    "data-original-display-start-jd=\"#{schedule_display_start_date.jd}\"",
                                    "data-original-display-due-jd=\"#{schedule_display_due_date.jd}\"",
                                    "data-anchor-jd=\"#{schedule_anchor_date.jd}\"",
                                    "data-virtual-schedule=\"#{schedule_virtual}\"",
                                    "data-update-url=\"#{h(schedule_update_url)}\""
                                  ].join(' ').html_safe
                                end
          schedule_drag_left = schedule_draggable ? (schedule_display_start_date - schedule_anchor_date).to_i * cell_width : 0
          schedule_drag_width = schedule_draggable ? (schedule_display_due_date - schedule_display_start_date + 1).to_i * cell_width : line_width

          # 작업 바 시작 위치 (차트 시작 이전에 시작했으면 차트 왼쪽 끝에 고정)
          bar_anchor_date = if issue_begin_date.nil?
                              nil
                            elsif issue_begin_date >= start_date && issue_begin_date <= end_date
                              issue_begin_date
                            elsif issue_begin_date < start_date && issue_end_date >= start_date
                              start_date
                            end
          show_bar = bar_anchor_date && !Tracker.is_exception?( issue.tracker_id )
          bar_left = show_bar ? ( bar_anchor_date - start_date ).to_i * cell_width : nil
          bar_width = if !show_bar then
                        0
                      elsif issue_begin_date != issue_end_date then
                        [1,  ( issue_end_date - bar_anchor_date + 1 ).to_i ].max * cell_width
                      else
                        if issue.end_time.nil?
                          cell_width
                        else
                          if ( issue.end_time - issue.begin_time ) >= 4.hour then
                            cell_width
                          elsif ( issue.end_time - issue.begin_time ) >= 1.hour then
                            ( cell_width * 0.5 ).to_i
                          else
                            3
                          end
                        end
                      end

          tip_date = [ issue.due_date, issue.end_time&.to_date, ( issue.end_time.nil? && issue.begin_time ? Date.today : nil ) ].compact.max
          show_tip = issue.tip && !virtual_ids.include?(issue.id) && tip_date && tip_date >= start_date && tip_date <= end_date
        %>

        <div class="task-lane mouseover-<%=gantt_container_id%><%= show_no_due_date_warning ? ' n' : '' %>"
             style="height: <%=cell_height%>px; background-image: repeating-linear-gradient(to right, transparent 0, transparent <%= cell_width - 1 %>px, #eee <%= cell_width - 1 %>px, #eee <%= cell_width %>px);">

          <!-- 작업완료 or 작업중 이슈 -->
          <% if show_bar then %>
            <div class="task-bar<%= IssueStatus.is_implemented?( issue.status_id ) ? ' completed' : '' %>" style="left: <%= bar_left %>px; top: 1px; width: <%= bar_width %>px; height: <%=cell_height-4%>px; position: absolute; z-index: 1;" data-issue-tooltip="<%= issue.id %>">
              <% if IssueStatus.is_in_progress?( issue.status_id ) %>
                <div class="task-bar-progress" style="width: <%= issue.done_ratio %>%;"></div>
              <% end %>
              <%# review 구간 오버레이 %>
              <% (review_periods_map[issue.id] || []).each do |period| %>
                <% if (segment = gantt_bar_period_segment(period, bar_anchor_date, issue_end_date, cell_width)) %>
                  <div class="task-bar-review" style="left: <%= segment[:left_px] %>px; width: <%= segment[:width_px] %>px;"></div>
                <% end %>
              <% end %>
              <%# paused 구간 오버레이 %>
              <% (paused_periods_map[issue.id] || []).each do |period| %>
                <% if (segment = gantt_bar_period_segment(period, bar_anchor_date, issue_end_date, cell_width)) %>
                  <div class="task-bar-paused" style="left: <%= segment[:left_px] %>px; width: <%= segment[:width_px] %>px;"></div>
                <% end %>
              <% end %>
            </div>
            <div class="task-tooltip-hit" data-issue-tooltip="<%= issue.id %>" style="position: absolute; left: <%= bar_left %>px; top: 0; width: <%= (show_line && line_left == bar_left && line_hit_width > bar_width) ? line_hit_width : bar_width %>px; height: <%= cell_height %>px; z-index: 50;"></div>
          <% end %>

          <% if show_tip %>
            <div class="gantt-tip-label" style="left: <%= ( tip_date - start_date + 1 ).to_i * cell_width + 2 %>px; width: <%= cell_width * 10 %>px;"><%=issue.tip%></div>
          <% end %>

          <% issue_progress_status_history.each do |history_date, status_name| %>
            <% next unless history_date >= start_date && history_date <= end_date %>
            <% next unless history_date < issue_end_date %>
            <% next unless issue_begin_date.nil? || issue_begin_date < history_date %>
            <div class="gantt-status-label" style="left: <%= ( history_date - start_date ).to_i * cell_width + 2 %>px; width: <%= cell_width * 10 %>px;"><%= status_name %></div>
          <% end %>

          <!-- 예정 이슈 -->
          <% if show_line && line_in_range %>
            <%
              line_classes = ['arrow-line']
              line_classes << 'show-before' if show_line_before
              line_classes << 'show-after' if show_line_after
              line_state_classes = gantt_schedule_line_css_classes(issue, virtual_ids)
              line_classes << line_state_classes if line_state_classes.present?
              visible_line_end_date = [line_end_date, end_date].min
              planning_edge_classes = gantt_schedule_line_edge_css_classes(planning_segments, line_start_date, visible_line_end_date)
              line_classes.concat(planning_edge_classes.split) if planning_edge_classes.present?
              delayed_schedule_segment = gantt_delayed_schedule_segment(issue, line_start_date, visible_line_end_date)
            %>
            <% unless planning_only_line %>
              <div class="<%= line_classes.join(' ') %> gantt-schedule-line<%= schedule_draggable ? ' gantt-schedule-editable' : '' %>"
                   style="left: <%= line_left %>px; width: <%=line_width %>px; top: <%= cell_height -3 %>px;"
                   data-issue-tooltip="<%= issue.id %>"
                   <% if schedule_draggable %><%= schedule_drag_attrs %><% end %>></div>
            <% end %>
            <% planning_segments.each do |segment| %>
              <%
                planning_start_date = [segment[:start_date], line_start_date].max
                planning_end_date = [segment[:due_date], visible_line_end_date].min
                next if planning_start_date > planning_end_date

                planning_left = (planning_start_date - line_start_date).to_i * cell_width
                planning_width = (planning_end_date - planning_start_date + 1).to_i * cell_width
              %>
              <div class="arrow-line-planning-segment" style="left: <%= line_left + planning_left %>px; width: <%= planning_width %>px; top: <%= cell_height -3 %>px;" data-issue-tooltip="<%= issue.id %>"></div>
            <% end %>
            <% if delayed_schedule_segment %>
              <%
                delayed_left = (delayed_schedule_segment[:start_date] - line_start_date).to_i * cell_width
                delayed_width = (delayed_schedule_segment[:due_date] - delayed_schedule_segment[:start_date] + 1).to_i * cell_width
                delayed_segment_classes = ['arrow-line-delayed-segment']
                delayed_segment_classes << gantt_delayed_schedule_age_class(issue)
                delayed_segment_classes << 'show-after' if delayed_schedule_segment[:due_date] == visible_line_end_date && show_line_after
              %>
              <div class="<%= delayed_segment_classes.join(' ') %>" style="left: <%= line_left + delayed_left %>px; width: <%= delayed_width %>px; top: <%= cell_height -3 %>px;" data-issue-tooltip="<%= issue.id %>"></div>
            <% end %>
            <% if overrun_extension_width > 0 %>
              <div class="arrow-line-overrun" style="left: <%= line_left + line_width %>px; width: <%= overrun_extension_width %>px; top: <%= cell_height -3 %>px;" data-issue-tooltip="<%= issue.id %>"></div>
            <% end %>
            <% unless show_bar && bar_left == line_left %>
              <div class="task-tooltip-hit" data-issue-tooltip="<%= issue.id %>" style="position: absolute; left: <%= line_left %>px; top: 0; width: <%= line_hit_width %>px; height: <%= cell_height %>px; z-index: 50;"></div>
            <% end %>
            <% if schedule_draggable %>
              <div class="gantt-schedule-draggable gantt-schedule-move-hit"
                   data-issue-tooltip="<%= issue.id %>"
                   <%= schedule_drag_attrs %>
                   data-drag-mode="move"
                   style="position: absolute; left: <%= schedule_drag_left %>px; top: 0; width: <%= schedule_drag_width %>px; height: <%= cell_height %>px; z-index: 55;"></div>
            <% end %>
            <% if schedule_draggable && schedule_has_start_date && schedule_display_start_date > start_date %>
              <div class="gantt-schedule-draggable gantt-schedule-resize-hit"
                   data-issue-tooltip="<%= issue.id %>"
                   <%= schedule_drag_attrs %>
                   data-drag-mode="start"
                   style="left: <%= schedule_drag_left - cell_width %>px; width: <%= cell_width %>px;"></div>
            <% end %>
            <% if schedule_draggable && schedule_has_due_date && schedule_display_due_date < end_date %>
              <div class="gantt-schedule-draggable gantt-schedule-resize-hit"
                   data-issue-tooltip="<%= issue.id %>"
                   <%= schedule_drag_attrs %>
                   data-drag-mode="due"
                   style="left: <%= schedule_drag_left + schedule_drag_width %>px; width: <%= cell_width %>px;"></div>
            <% end %>
          <% end %>

        </div>
      <% end %>

    </div>
  </div>
</div>
<% end %>

<%= context_menu %>

<script>
  $(function() {
    TxMilestoneGanttChart.init('<%= gantt_container_id %>');
  });
</script>
