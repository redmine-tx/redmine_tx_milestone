  color: #004085;
  margin-bottom: 8px;
}

.getting-started p {
  color: #004085;
  margin: 0;
  font-weight: 500;
}

@media (max-width: 768px) {
  .milestone-welcome .box {
    padding: 15px;
  }
  
  .feature-item {
    padding: 12px;
  }
}
</style>