<%
  summary = RedmineTxMilestone::IssueDetailScheduleSummary.build(issue)
  root_issue = summary[:root_issue]
  container_id = "tx-milestone-issue-schedule-summary-#{issue.id}"
  timeline_container_id = "#{container_id}-timeline"
  resize_namespace = container_id.gsub(/[^a-zA-Z0-9_]/, '_')

  json_data = {
    options: {
      categoryLabel: '팀',
      eventLabel: '담당자',
      rowHeight: 15,
      showScheduleName: true,
      startDate: summary[:display_start_date].strftime('%Y-%m-%d'),
      holidays: summary[:holidays]
    },
    categories: [],
    legends: []
  }

  in_progress_status_ids = IssueStatus.new_ids + IssueStatus.in_progress_ids + IssueStatus.in_review_ids
  hidden_teammate_events_by_category_index = {}

  summary[:result_data].each_with_index do |(group, users_issues), category_index|
    category = {
      name: group.name,
      customColor: nil,
      events: []
    }

    users_issues.each do |user, user_issues|
      event = {
        name: user.name,
        login: user.login,
        link: user_path(user),
        schedules: []
      }

      Array(summary[:background_issues_by_user][user.id]).each do |background_issue|
        background_in_progress = in_progress_status_ids.include?(background_issue.status_id)
        event[:schedules] << {
          name: "##{background_issue.id} : #{background_issue.subject}",
          startDate: background_issue.start_date.strftime('%Y-%m-%d'),
          endDate: background_issue.due_date.strftime('%Y-%m-%d'),
          issue: "##{background_issue.id}",
          issueId: background_issue.id.to_s,
          doneRatio: background_issue.done_ratio || 0,
          link: issue_path(background_issue),
          customColor: '#e0e0e0',
          customFontColor: background_in_progress ? '#555555' : '#AAAAAA',
          isMuted: true
        }
      end

      user_issues.each do |scheduled_issue|
        main_issue_id = summary[:issue_to_main_issue][scheduled_issue.id]
        issue_color = summary[:main_issue_colors][main_issue_id] || '#999999'
        issue_in_progress = in_progress_status_ids.include?(scheduled_issue.status_id)

        event[:schedules] << {
          name: "##{scheduled_issue.id} : #{scheduled_issue.subject}",
          startDate: scheduled_issue.start_date.strftime('%Y-%m-%d'),
          endDate: scheduled_issue.due_date.strftime('%Y-%m-%d'),
          issue: "##{scheduled_issue.id}",
          issueId: scheduled_issue.id.to_s,
          doneRatio: scheduled_issue.done_ratio || 0,
          link: issue_path(scheduled_issue),
          customColor: issue_color,
          customFontColor: issue_in_progress ? '#555555' : '#AAAAAA'
        }
      end

      category[:events] << event
    end

    Array(summary[:hidden_teammates_by_group][group]).each do |user|
      hidden_teammate_events_by_category_index[category_index] ||= []

      event = {
        name: user.name,
        login: user.login,
        link: user_path(user),
        schedules: []
      }

      Array(summary[:background_issues_by_user][user.id]).each do |background_issue|
        background_in_progress = in_progress_status_ids.include?(background_issue.status_id)
        event[:schedules] << {
          name: "##{background_issue.id} : #{background_issue.subject}",
          startDate: background_issue.start_date.strftime('%Y-%m-%d'),
          endDate: background_issue.due_date.strftime('%Y-%m-%d'),
          issue: "##{background_issue.id}",
          issueId: background_issue.id.to_s,
          doneRatio: background_issue.done_ratio || 0,
          link: issue_path(background_issue),
          customColor: '#e0e0e0',
          customFontColor: background_in_progress ? '#555555' : '#AAAAAA',
          isMuted: true
        }
      end

      hidden_teammate_events_by_category_index[category_index] << event
    end

    json_data[:categories] << category
  end

  summary[:parent_issues].each do |parent_issue|
    json_data[:legends] << {
      title: "##{parent_issue.id} : #{parent_issue.subject.to_s.truncate(30)}",
      color: summary[:main_issue_colors][parent_issue.id],
      url: issue_path(parent_issue)
    }
  end
%>

<% if summary[:result_data].any? %>
  <%= javascript_include_tag 'tx_timeline_grid', plugin: 'redmine_tx_0_base' %>
  <%= stylesheet_link_tag 'tx_timeline_grid', plugin: 'redmine_tx_0_base' %>
  <%= javascript_include_tag 'tx_milestone_schedule_summary', plugin: 'redmine_tx_milestone' %>
<% end %>

<style>
  .tx-milestone-issue-schedule-summary {
    margin-top: 16px;
  }

  .tx-milestone-issue-schedule-summary h3 {
    margin: 0 0 10px;
  }

  .tx-milestone-issue-schedule-summary .tx-schedule-summary-toggle {
    margin-right: 6px;
  }

  .tx-milestone-issue-schedule-summary .tx-schedule-summary-meta {
    color: #666;
    font-size: 0.9em;
    margin: 8px 0 0;
  }

  .tx-milestone-issue-schedule-summary .tx-schedule-summary-empty {
    color: #888;
    font-style: italic;
    padding: 12px;
    text-align: center;
  }

  .tx-milestone-issue-schedule-summary .schedule-team-expand-control {
    margin-left: 4px;
    white-space: nowrap;
  }

  .tx-milestone-issue-schedule-summary .schedule-team-expand-toggle {
    cursor: pointer;
    font-size: 0.9em;
    font-weight: normal;
  }

  .tx-milestone-issue-schedule-summary .schedule-team-expand-toggle:hover {
    text-decoration: underline;
  }

  .tx-milestone-issue-schedule-summary {
    --vacation-x-line-half-width: 0.5px;
  }

  .tx-milestone-issue-schedule-summary .tx-schedule-cell.tx-full-day-vacation-cell:not(.tx-schedule-bar) {
    background-image:
      linear-gradient(
        to top right,
        transparent calc(50% - var(--vacation-x-line-half-width)),
        rgba(80, 80, 80, 0.35) calc(50% - var(--vacation-x-line-half-width)),
        rgba(80, 80, 80, 0.35) calc(50% + var(--vacation-x-line-half-width)),
        transparent calc(50% + var(--vacation-x-line-half-width))
      ),
      linear-gradient(
        to bottom right,
        transparent calc(50% - var(--vacation-x-line-half-width)),
        rgba(80, 80, 80, 0.35) calc(50% - var(--vacation-x-line-half-width)),
        rgba(80, 80, 80, 0.35) calc(50% + var(--vacation-x-line-half-width)),
        transparent calc(50% + var(--vacation-x-line-half-width))
      );
    background-repeat: no-repeat;
    background-size: 100% 100%;
    background-position: center;
  }

  .tx-milestone-issue-schedule-summary .tx-schedule-bar.tx-full-day-vacation-cell {
    position: relative;
    background-image: none;
  }

  .tx-milestone-issue-schedule-summary .tx-schedule-bar.tx-full-day-vacation-cell .tx-schedule-bar-content {
    position: relative;
    z-index: 1;
  }

  .tx-milestone-issue-schedule-summary .tx-full-day-vacation-segment {
    position: absolute;
    top: 0;
    bottom: 0;
    pointer-events: none;
    z-index: 0;
    background-image:
      linear-gradient(
        to top right,
        transparent calc(50% - var(--vacation-x-line-half-width)),
        rgba(80, 80, 80, 0.35) calc(50% - var(--vacation-x-line-half-width)),
        rgba(80, 80, 80, 0.35) calc(50% + var(--vacation-x-line-half-width)),
        transparent calc(50% + var(--vacation-x-line-half-width))
      ),
      linear-gradient(
        to bottom right,
        transparent calc(50% - var(--vacation-x-line-half-width)),
        rgba(80, 80, 80, 0.35) calc(50% - var(--vacation-x-line-half-width)),
        rgba(80, 80, 80, 0.35) calc(50% + var(--vacation-x-line-half-width)),
        transparent calc(50% + var(--vacation-x-line-half-width))
      );
    background-repeat: no-repeat;
    background-size: 100% 100%;
    background-position: center;
  }
</style>

<div id="<%= container_id %>" class="tx-milestone-issue-schedule-summary" style="display: none;">
  <hr>
  <div class="contextual">
    <button type="button"
            class="button tx-schedule-summary-toggle"
            data-tx-schedule-summary-toggle
            aria-expanded="true">접기</button>
    <%= link_to '전체 일정요약',
                { controller: 'milestone', action: 'schedule_summary', project_id: root_issue.project.identifier, issue_ids: root_issue.id },
                target: '_blank',
                class: 'icon icon-stats' %>
  </div>
  <h3>일정요약 간트</h3>

  <div data-tx-schedule-summary-body>
    <% if summary[:result_data].any? %>
      <div id="<%= timeline_container_id %>"></div>
      <% if summary[:full_day_vacation_map].any? %>
        <p class="tx-schedule-summary-meta">그리드의 <strong>X</strong> 표시는 해당 날짜 전일 휴가입니다.</p>
      <% end %>
      <p class="tx-schedule-summary-meta">
        전체 일감(하위 포함, 실제 구현 일감만): <strong><%= summary[:total_issue_count] %>개</strong> |
        요약된 일감(담당자/일정 있음): <strong><%= summary[:summarized_issue_count] %>개</strong>
      </p>
    <% else %>
      <div class="tx-schedule-summary-empty">표시할 일정요약 데이터가 없습니다.</div>
    <% end %>
  </div>
</div>

<script>
$(function() {
  var $panel = $('#<%= j container_id %>');
  var $relations = $('#relations');
  var $issueTree = $('#issue_tree');

  if ($relations.length > 0) {
    $panel.insertAfter($relations);
  } else if ($issueTree.length > 0) {
    $panel.insertAfter($issueTree);
  } else {
    $panel.appendTo($('.details').first());
  }

  var storageKey = 'redmine_tx_milestone.issue_detail_schedule_summary.collapsed.user.<%= j User.current.id.to_s %>';
  var $body = $panel.find('[data-tx-schedule-summary-body]');
  var $toggle = $panel.find('[data-tx-schedule-summary-toggle]');

  function storedCollapsedState() {
    try {
      return window.localStorage && window.localStorage.getItem(storageKey) === 'true';
    } catch (error) {
      return false;
    }
  }

  function storeCollapsedState(collapsed) {
    try {
      if (window.localStorage) {
        window.localStorage.setItem(storageKey, collapsed ? 'true' : 'false');
      }
    } catch (error) {
    }
  }

  function setCollapsed(collapsed) {
    $body.toggle(!collapsed);
    $toggle.text(collapsed ? '펴기' : '접기')
           .attr('aria-expanded', collapsed ? 'false' : 'true');
  }

  setCollapsed(storedCollapsedState());
  $toggle.on('click', function() {
    var collapsed = $body.is(':visible');
    setCollapsed(collapsed);
    storeCollapsedState(collapsed);
  });

  $panel.show();

  <% if summary[:result_data].any? %>
  var jsonDataBase = <%= raw json_escape(json_data.to_json) %>;
  var hiddenTeammateEventsByCategoryIndex = <%= raw json_escape(hidden_teammate_events_by_category_index.to_json) %>;
  var expandedCategoryIndexes = {};
  var currentJsonData = null;
  var fullDayVacationMap = <%= raw json_escape(summary[:full_day_vacation_map].to_json) %>;
  var verticalMarkers = <%= raw json_escape(summary[:version_markers].to_json) %>;
  var timelineSelector = '#<%= j timeline_container_id %>';

  function injectTeamExpandControls() {
    var container = document.querySelector(timelineSelector);
    if (!container) return;

    Object.keys(hiddenTeammateEventsByCategoryIndex).forEach(function(categoryIndexKey) {
      var hiddenCount = (hiddenTeammateEventsByCategoryIndex[categoryIndexKey] || []).length;
      if (hiddenCount === 0) return;

      var row = container.querySelector('tbody tr.tx-category-start[data-category="' + categoryIndexKey + '"]');
      if (!row) return;

      var categoryCell = row.querySelector('td.tx-category-cell');
      if (!categoryCell) return;

      var isExpanded = !!expandedCategoryIndexes[categoryIndexKey];
      var control = document.createElement('span');
      control.className = 'schedule-team-expand-control';

      var toggleLink = document.createElement('a');
      toggleLink.href = '#';
      toggleLink.className = 'schedule-team-expand-toggle';
      toggleLink.setAttribute('aria-expanded', isExpanded ? 'true' : 'false');
      toggleLink.title = isExpanded ? '비관여 팀원 숨기기' : '이 팀의 비관여 팀원 표시';
      toggleLink.textContent = isExpanded ? '(-' + hiddenCount + ')' : '(+' + hiddenCount + ')';
      toggleLink.addEventListener('click', function(event) {
        event.preventDefault();
        expandedCategoryIndexes[categoryIndexKey] = !expandedCategoryIndexes[categoryIndexKey];
        renderTimeline('auto');
      });

      control.appendChild(toggleLink);
      categoryCell.appendChild(control);
    });
  }

  function renderTimeline(scrollBehavior) {
    currentJsonData = TxMilestoneScheduleSummary.buildTimelineData(jsonDataBase, hiddenTeammateEventsByCategoryIndex, expandedCategoryIndexes);
    TxTimelineGrid.render(timelineSelector, currentJsonData, {
      verticalMarkers: verticalMarkers,
      scrollToToday: true,
      scrollAlign: 'center',
      scrollBehavior: scrollBehavior || 'auto'
    });
    TxMilestoneScheduleSummary.decorateFullDayVacationCells(timelineSelector, currentJsonData, fullDayVacationMap);
    injectTeamExpandControls();
  }

  try {
    if (!window.TxTimelineGrid) {
      throw new Error('TxTimelineGrid is not loaded');
    }

    renderTimeline('auto');
  } catch (error) {
    $(timelineSelector).html('<div class="tx-schedule-summary-empty">타임라인 렌더링 중 오류가 발생했습니다.</div>');
    if (window.console && console.error) console.error('일정요약 타임라인 렌더링 오류:', error);
  }

  $(window).off('resize.<%= j resize_namespace %>').on('resize.<%= j resize_namespace %>', function() {
    if (currentJsonData) {
      TxMilestoneScheduleSummary.decorateFullDayVacationCells(timelineSelector, currentJsonData, fullDayVacationMap);
    }
  });
  <% end %>
});
</script>
